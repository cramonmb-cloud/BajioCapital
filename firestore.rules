rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CREDICONTROL SECURITY RULES (V2 - ESTRUCTURA PLANA)
     *
     * Estas reglas han sido actualizadas para soportar la estructura de colecciones
     * de primer nivel utilizada en el código de React y los roles 'admin' y 'supervisor'.
     */

    // --- FUNCIONES DE AYUDA ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    function isSupervisor() {
      return isSignedIn() && getUserData().role == 'supervisor';
    }

    function isStaff() {
      return isAdmin() || isSupervisor();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- REGLAS POR COLECCIÓN ---

    // Perfiles de usuario
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Clientes
    match /clients/{clientId} {
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // Préstamos (Estructura plana)
    match /loans/{loanId} {
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // Planes de préstamo
    match /loanPlans/{planId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // Estructura Operativa (Plazas, Localidades, Promotoras)
    match /plazas/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }
    match /localidades/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }
    match /promotoras/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // Cartera y Finanzas
    match /wallet/{id} {
      allow read: if isStaff();
      allow write: if isStaff(); // Necesario para registrar pagos
    }
    match /walletTransactions/{id} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    // Configuración Global
    match /config/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }
  }
}